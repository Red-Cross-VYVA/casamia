{
  "name": "casamia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:production": "npm run validate:legal-config && npm run build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "node scripts/legal-launch-checks.mjs && npm run test:auth && npm run test:voice && npm run test:callback && npm run test:callbacks-admin && npm run test:operations && npm run test:wizard && npm run test:report && npm run test:configurator && npm run test:links && npm run test:tech && npm run test:assisted && npm run test:how-it-works",
    "test:assisted": "node scripts/assisted-living-page-tests.mjs",
    "test:how-it-works": "node scripts/how-it-works-page-tests.mjs",
    "test:auth": "node --experimental-strip-types scripts/internal-auth-tests.mjs",
    "test:links": "node scripts/link-checks.mjs",
    "test:operations": "node scripts/operations-connection-tests.mjs",
    "test:configurator": "node --experimental-strip-types scripts/configurator-pricing-tests.mjs",
    "test:callback": "node --experimental-strip-types scripts/callback-request-tests.mjs",
    "test:callbacks-admin": "node scripts/internal-callback-tests.mjs",
    "test:voice": "node scripts/voice-assistant-tests.mjs",
    "test:tech": "node scripts/tech-page-tests.mjs",
    "test:wizard": "node --experimental-strip-types scripts/home-safety-wizard-tests.mjs",
    "test:report": "node --experimental-strip-types scripts/safety-report-tests.mjs",
    "validate:legal-config": "node scripts/validate-legal-config.mjs"
  },
  "dependencies": {
    "@elevenlabs/react": "^1.10.1",
    "i18next": "^26.3.2",
    "lucide-react": "^1.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
