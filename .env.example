# CasaMia production target:
# - Frontend and serverless API routes: Vercel
# - Durable storage: Supabase
#
# Vercel server-only environment variables. Do not prefix these with VITE_.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
CASAMIA_INTERNAL_API_KEY=replace-with-casamia-internal-api-key
CASAMIA_INTERNAL_PASSWORD=replace-with-admin-password
CASAMIA_INTERNAL_SESSION_SECRET=replace-with-long-random-session-secret

# Server-side room recognition and safety analysis for wizard photo uploads.
# Never use a VITE_ prefix or expose this key in browser code.
OPENAI_API_KEY=replace-with-restricted-openai-api-key
# Optional. By default, room classification uses gpt-5.6-luna and the more
# detailed safety analysis uses gpt-5.6-terra. Set this to override both.
# OPENAI_VISION_MODEL=gpt-5.6-terra
# Optional. Used for server-side grant route research after a user submits
# the grant-readiness report. Defaults to OPENAI_VISION_MODEL or gpt-5.6-terra.
# OPENAI_GRANT_RESEARCH_MODEL=gpt-5.6-terra

# Optional local-development fallback. When no local OPENAI_API_KEY is set,
# Vite can relay vision requests to the deployed CasaMia API without exposing
# server credentials to the browser.
# CASAMIA_DEV_VISION_API_URL=https://www.casamia.com.es

# ElevenLabs voice previews. These remain server-only.
ELEVENLABS_API_KEY=replace-with-restricted-elevenlabs-api-key
ELEVENLABS_VOICE_ID=replace-with-approved-casamia-voice-id
# Optional. Multilingual v2 is the default for stable multilingual guidance.
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ElevenLabs conversational agent used by the home-safety wizard. These also
# remain server-only. Configure the agent for English and Spanish and enable
# its language override in ElevenLabs.
ELEVENLABS_AGENT_ID=replace-with-casamia-agent-id
# Optional. Defaults shown below.
# ELEVENLABS_AGENT_ENVIRONMENT=production
# ELEVENLABS_SERVER_LOCATION=us
# Use a long independent secret in production for anonymous IP rate limiting.
# ELEVENLABS_RATE_LIMIT_SALT=replace-with-long-random-secret
# Optional comma-separated frontend origins when the wizard and API are served
# from different domains. Same-origin Vercel deployments need no extra value.
# CASAMIA_ALLOWED_ORIGINS=https://www.casamia.com.es

# Optional independent secret used to HMAC anonymous IP addresses for callback
# request rate limiting. If omitted, an existing server-only CasaMia/Supabase
# secret is used. Never expose this with a VITE_ prefix.
# CALLBACK_RATE_LIMIT_SALT=replace-with-long-random-secret

# Public website URL for canonical SEO links.
VITE_SITE_URL=https://www.casamia.example

# Keeps all customer-facing voice UI off until the voice and scripts are approved.
VITE_ENABLE_VOICE_ASSISTANT=false

# Public contact channels used by the home-safety wizard.
# VITE_CASAMIA_CONTACT_PHONE=replace-with-public-phone-number
# VITE_CASAMIA_WHATSAPP_URL=https://wa.me/replace-with-public-whatsapp-number

# Optional browser-side API overrides.
# Leave these blank on Vercel so the app uses same-origin /api routes.
# VITE_PUBLIC_SITE_API_URL=https://your-vercel-domain.vercel.app
# VITE_ASSESSMENT_SUBMIT_URL=https://your-vercel-domain.vercel.app/api/public/assessment-requests
# VITE_PROVIDER_APPLICATION_API_URL=https://your-vercel-domain.vercel.app/api/public/provider-applications
# VITE_CONSENT_EVIDENCE_API_URL=https://your-vercel-domain.vercel.app/api/consent-evidence
# VITE_WITHDRAWAL_API_URL=https://your-vercel-domain.vercel.app/api/withdrawal-requests
# VITE_ORDER_API_URL=https://your-vercel-domain.vercel.app/api/public/orders

# Internal admin:
# /internal uses a password login. Keep the values above server-only and do not
# expose them with a VITE_ prefix. Vercel Deployment Protection is still
# recommended for an extra layer around the internal route.
